# ============================================================
# Omni — development API keys — TEMPLATE ONLY, THIS FILE IS COMMITTED TO GIT.
# DO NOT paste real keys here. Copy this file to `.env` (which IS gitignored)
# and paste your values there, after the = sign, no quotes needed.
# ============================================================

# --- REQUIRED (the app runs fully on these two) ---

# Groq — free at https://console.groq.com/keys
GROQ_API_KEY=

# Gemini — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- OPTIONAL ---

# Anthropic — only if you want Claude as the premium synthesis/agent tier
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google OAuth desktop client (for Calendar / Contacts / Gmail-draft tools, M4)
# Create at https://console.cloud.google.com/apis/credentials
#   -> Create Credentials -> OAuth client ID -> Desktop app
#   -> enable APIs: Google Calendar API, People API, Gmail API
#   -> OAuth consent screen: External, add yourself as test user
# Can be added AFTER you get back — I'll build M4 against mocks until then.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
