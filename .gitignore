# Secrets — never committed
.env
.env.*
!.env.example
*.pem
credentials.json
token.json
client_secret*.json
# Tauri updater signing key lives at %LOCALAPPDATA%/Omni/updater-signing-key —
# never in the repo. Belt-and-braces pattern in case one is ever copied here.
*updater-signing-key*

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.spec.bak

# Node
node_modules/
apps/ui/dist/

# Rust / Tauri
apps/ui/src-tauri/target/

# Models & data (downloaded at first run, never committed)
models/
*.onnx
*.nemo
*.wav
*.db
*.sqlite*

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/

# packaging: track only the bundle-resource placeholder, not the built engine
!packaging/dist/
!packaging/dist/omni-engine/
!packaging/dist/omni-engine/PLACEHOLDER.txt
packaging/dist/omni-engine/*
!packaging/dist/omni-engine/PLACEHOLDER.txt

# live E2E runtime + generated artifacts (never committed; regenerated per run)
.e2e-run/
apps/ui/e2e/playwright-report/
apps/ui/test-results/
apps/ui/playwright-report/
