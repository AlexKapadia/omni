{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omni Steroid",
  "version": "0.1.0",
  "identifier": "com.omni.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Omni Steroid",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:8765; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app", "deb", "appimage"],
    "publisher": "Omni Steroid",
    "copyright": "MIT License",
    "shortDescription": "Local-first meeting intelligence",
    "longDescription": "Omni Steroid: local-first, bot-free meeting intelligence. On-device transcription, enhanced notes into your Obsidian vault, approval-carded actions, zero telemetry. Windows, macOS, and Linux builds.",
    "licenseFile": "../../../LICENSE",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../packaging/dist/omni-engine": "omni-engine",
      "../../../packaging/install-stt-runtime.ps1": "stt-runtime/install-stt-runtime.ps1",
      "../../../packaging/install-stt-runtime.sh": "stt-runtime/install-stt-runtime.sh",
      "../../../packaging/stt-runtime-requirements.txt": "stt-runtime/stt-runtime-requirements.txt"
    },
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGREYzNDYzMDFBQUY0MDYKUldRRzlLb0JZelRmWDI2TkYveHVzcjN2UENPQWpUT0hNOEtDNFQyeEtERXE3aHZiRGJBSTBWa0EK",
      "endpoints": [
        "https://github.com/bhaskaraanjana/omni/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
